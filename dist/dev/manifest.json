{
  "version": "1.9.3",
  "manifest_version": 3,
  "content_scripts": [
    {
      "matches": [
        "*://www.pathofexile.com/trade*",
        "*://pathofexile.com/trade*"
      ],
      "js": [
        "ember-build/assets/vendor.js",
        "ember-build/assets/better-trading.js"
      ],
      "css": [
        "ember-build/assets/vendor.css",
        "ember-build/assets/better-trading.css"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://poe.ninja/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "ember-build/assets/images/*"
      ],
      "matches": [
        "*://www.pathofexile.com/*",
        "*://pathofexile.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "64": "icon64.png",
    "128": "icon128.png"
  },
  "name": "Better PathOfExile Trading",
  "description": ""
}